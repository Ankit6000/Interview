# Pick one provider. OpenRouter is easiest for free/community DeepSeek models.
# Free model availability changes often, so check the model page if one stops working.

OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Optional direct DeepSeek API. Official DeepSeek API is usually paid/usage-based.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Optional xAI/Grok API. Grok is separate from DeepSeek.
XAI_API_KEY=
XAI_MODEL=grok-4.1-fast

PORT=3000
